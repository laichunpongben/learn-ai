---
/**
 * A Claude Code imitation. Streaming output, working-directory line,
 * arrow-key slash menu, and an "allow / deny" prompt when Claude would
 * run a tool that touches your machine.
 */
interface Props {
  cwd?: string;
}
const { cwd = "~/my-project" } = Astro.props;
---

<div class="term-app" data-term style={`--cwd: '${cwd}';`}>
  <div class="term-head">
    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
    <span class="tt">{cwd} — claude</span>
  </div>
  <div class="term-body" data-term-body>
    <div class="line out">Welcome to Claude Code (pretend edition).</div>
    <div class="line out muted">Try: <code>/help</code> · <code>fix the bug</code> · <code>list files</code></div>
  </div>

  <div class="menu" data-term-menu>
    <div class="menu-row" data-cmd="/help" data-i="0"><code>/help</code><span>show what I can do</span></div>
    <div class="menu-row" data-cmd="/agents" data-i="1"><code>/agents</code><span>list specialized assistants</span></div>
    <div class="menu-row" data-cmd="/plan" data-i="2"><code>/plan</code><span>plan first, code later</span></div>
    <div class="menu-row" data-cmd="/clear" data-i="3"><code>/clear</code><span>start a fresh chat</span></div>
    <div class="menu-row" data-cmd="/model" data-i="4"><code>/model</code><span>switch model (Sonnet/Opus/Haiku)</span></div>
    <div class="menu-row" data-cmd="/exit" data-i="5"><code>/exit</code><span>leave the session</span></div>
  </div>

  <div class="prompt-row" data-prompt-row>
    <span class="cwd">{cwd}</span>
    <span class="caret">›</span>
    <input type="text" data-term-input placeholder="Type a request, or / for commands…" autocomplete="off" spellcheck="false" />
  </div>
</div>

<style>
  .term-app {
    background: #0d0d0d;
    color: #e5e5e5;
    border-radius: var(--radius);
    margin: 1.6rem 0;
    font-family: var(--mono);
    font-size: 0.82rem;
    overflow: hidden;
    position: relative;
    border: 1px solid #1f1f1f;
  }
  .term-head {
    background: #1a1a1a;
    padding: 0.45rem 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border-bottom: 1px solid #1f1f1f;
  }
  .term-head .dot {
    width: 10px; height: 10px; border-radius: 50%;
  }
  .term-head .dot.red { background: #ff5f57; }
  .term-head .dot.yellow { background: #febc2e; }
  .term-head .dot.green { background: #28c840; }
  .term-head .tt {
    margin-left: 0.7rem;
    color: #888;
    font-size: 0.74rem;
    font-family: var(--sans);
    font-weight: 500;
  }
  .term-body {
    padding: 0.95rem 1.05rem 0.5rem;
    min-height: 220px;
    max-height: 380px;
    overflow: auto;
    white-space: pre-wrap;
    line-height: 1.55;
  }
  .line { margin: 0.05rem 0; }
  .line.you { color: #e5e5e5; }
  .line.you::before { content: "› "; color: #cc5500; }
  .line.cmd { color: #d4b876; }
  .line.cmd::before { content: "› "; color: #cc5500; }
  .line.out { color: #a3a3a3; }
  .line.out.muted { color: #5a5a5a; }
  .line.tool { color: #7fb87a; }
  .line.tool::before { content: "● "; }
  .line.error { color: #e07b6a; }
  .line.assistant { color: #e5e5e5; }
  .approve {
    margin: 0.5rem 0;
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    padding: 0.55rem 0.75rem;
  }
  .approve .head {
    color: #cc5500;
    font-weight: 600;
    margin-bottom: 0.3rem;
    font-family: var(--sans);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .approve .body { color: #d4d4d4; }
  .approve .actions {
    margin-top: 0.5rem;
    display: flex;
    gap: 0.4rem;
  }
  .approve button {
    background: transparent;
    color: #e5e5e5;
    border: 1px solid #3a3a3a;
    border-radius: 4px;
    padding: 0.2rem 0.7rem;
    font: inherit;
    font-family: var(--sans);
    font-size: 0.78rem;
    cursor: pointer;
    font-weight: 500;
  }
  .approve button.allow:hover { background: #1f4129; border-color: #2d6b3f; color: #aae0b2; }
  .approve button.deny:hover { background: #3f1f1f; border-color: #6b2d2d; color: #e0aaaa; }
  .prompt-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.05rem 0.75rem;
    border-top: 1px solid #1f1f1f;
    background: #0a0a0a;
  }
  .prompt-row .cwd {
    color: #7fb87a;
    font-size: 0.78rem;
  }
  .prompt-row .caret { color: #cc5500; }
  .prompt-row input {
    background: transparent;
    border: none;
    outline: none;
    color: inherit;
    font: inherit;
    flex: 1;
    caret-color: #cc5500;
  }
  .prompt-row input::placeholder { color: #5a5a5a; }
  .menu {
    display: none;
    position: absolute;
    bottom: 50px;
    left: 1rem;
    right: 1rem;
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    padding: 0.3rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.6);
  }
  .menu.open { display: block; }
  .menu-row {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 0.6rem;
    padding: 0.35rem 0.55rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.82rem;
  }
  .menu-row code { color: #d4b876; font-family: var(--mono); background: transparent; border: none; padding: 0; }
  .menu-row span { color: #a3a3a3; font-family: var(--sans); font-size: 0.78rem; }
  .menu-row.sel { background: #262626; }
</style>

<script>
  import { motionDelay, prefersReducedMotion } from "../scripts/sim-motion";

  type Step = { kind: "tool" | "out" | "assistant"; text: string; needsApproval?: boolean };

  interface Scenario {
    steps: Step[];
  }

  const SCENARIOS: { match: RegExp; scenario: Scenario }[] = [
    {
      match: /^\/help$/i,
      scenario: {
        steps: [
          { kind: "out", text: "I can read your files, edit them, run commands, and call specialized agents." },
          { kind: "out", text: "Useful slash commands: /agents · /plan · /model · /clear · /exit" },
          { kind: "out", text: "Or just describe what you want: \"add a dark-mode toggle to the homepage\"." },
        ],
      },
    },
    {
      match: /^\/agents$/i,
      scenario: {
        steps: [
          { kind: "tool", text: "Reading ~/.claude/agents/" },
          { kind: "out", text: "  code-reviewer · reviews code after I write it" },
          { kind: "out", text: "  tdd-guide      · enforces tests-first when adding features" },
          { kind: "out", text: "  planner        · designs an approach before touching files" },
          { kind: "out", text: "  build-error-resolver · fixes failing builds" },
          { kind: "out", text: "  security-reviewer · flags risky code paths" },
        ],
      },
    },
    {
      match: /^\/plan$/i,
      scenario: {
        steps: [
          { kind: "out", text: "Plan mode on. I'll outline steps before touching files, and wait for your OK." },
        ],
      },
    },
    {
      match: /^\/clear$/i,
      scenario: { steps: [{ kind: "out", text: "(chat cleared)" }] },
    },
    {
      match: /^\/model$/i,
      scenario: {
        steps: [
          { kind: "out", text: "Model names change; these are example labels from the current family." },
          { kind: "out", text: "Available: claude-opus-4-7 · claude-sonnet-4-6 · claude-haiku-4-5" },
          { kind: "out", text: "Currently using: claude-sonnet-4-6 (the default — fast, strong on code)" },
        ],
      },
    },
    {
      match: /^\/exit$/i,
      scenario: { steps: [{ kind: "out", text: "Bye! Reopen with `claude` any time. Conversation saved." }] },
    },
    {
      match: /list files|show files|what files/i,
      scenario: {
        steps: [
          { kind: "tool", text: "Listing your project files" },
          { kind: "out", text: "  README.md\n  package.json\n  src/\n    index.ts\n    server.ts\n  tests/\n  .env.example" },
        ],
      },
    },
    {
      match: /fix.*bug|crash|error|not working/i,
      scenario: {
        steps: [
          { kind: "assistant", text: "Let me look. I'll need to read a couple of files first." },
          { kind: "tool", text: "Reading package.json", needsApproval: true },
          { kind: "tool", text: "Reading src/server.ts" },
          { kind: "tool", text: "Running npm test" },
          { kind: "out", text: "  FAIL  tests/server.test.ts\n    expected DATABASE_URL, got undefined" },
          { kind: "assistant", text: "Found it — the app reads DATABASE_URL but .env doesn't define one. Want me to add a placeholder to .env.example and a clearer startup error if it's missing?" },
        ],
      },
    },
    {
      match: /add.*toggle|dark mode|add.*button|add.*feature/i,
      scenario: {
        steps: [
          { kind: "assistant", text: "Sure. I'll scan the relevant files, propose a change, then make it." },
          { kind: "tool", text: "Reading src/Header.tsx" },
          { kind: "tool", text: "Reading src/styles/theme.css" },
          { kind: "assistant", text: "Plan:\n  1. Add `useTheme` hook (reads/writes localStorage)\n  2. Add toggle button to Header\n  3. Add `.dark` CSS variants in theme.css" },
          { kind: "tool", text: "Writing src/hooks/useTheme.ts", needsApproval: true },
          { kind: "tool", text: "Editing src/Header.tsx" },
          { kind: "tool", text: "Editing src/styles/theme.css" },
          { kind: "assistant", text: "Done — 3 files changed. Want me to run the tests?" },
        ],
      },
    },
    {
      match: /hi|hello|hey/i,
      scenario: { steps: [{ kind: "assistant", text: "Hi! What are we building? You can describe a task in your own words, or type / for built-in commands." }] },
    },
  ];

  function pickScenario(cmd: string): Scenario {
    const t = cmd.trim();
    for (const r of SCENARIOS) if (r.match.test(t)) return r.scenario;
    return {
      steps: [
        { kind: "assistant", text: `(pretend) I'd respond to "${t}" by reading your project and proposing a change. In the real CLI I'd actually do it.` },
      ],
    };
  }

  document.querySelectorAll<HTMLElement>("[data-term]").forEach((root) => {
    const body = root.querySelector<HTMLElement>("[data-term-body]")!;
    const input = root.querySelector<HTMLInputElement>("[data-term-input]")!;
    const menu = root.querySelector<HTMLElement>("[data-term-menu]")!;
    const rows = Array.from(menu.querySelectorAll<HTMLElement>(".menu-row"));
    let sel = 0;
    let busy = false;

    function paintMenuSel() {
      rows.forEach((r, i) => r.classList.toggle("sel", i === sel));
    }

    function openMenu() {
      menu.classList.add("open");
      sel = 0;
      paintMenuSel();
    }
    function closeMenu() {
      menu.classList.remove("open");
    }

    function pushLine(kind: string, text: string) {
      const div = document.createElement("div");
      div.className = `line ${kind}`;
      div.textContent = text;
      body.appendChild(div);
      body.scrollTop = body.scrollHeight;
      return div;
    }

    function askApproval(label: string): Promise<boolean> {
      return new Promise((resolve) => {
        const box = document.createElement("div");
        box.className = "approve";
        box.innerHTML = `
          <div class="head">Claude wants to do this</div>
          <div class="body">${label}</div>
          <div class="actions">
            <button class="allow">Allow</button>
            <button class="deny">Deny</button>
          </div>
        `;
        body.appendChild(box);
        body.scrollTop = body.scrollHeight;
        box.querySelector<HTMLButtonElement>(".allow")!.addEventListener("click", () => {
          box.remove();
          resolve(true);
        });
        box.querySelector<HTMLButtonElement>(".deny")!.addEventListener("click", () => {
          box.remove();
          resolve(false);
        });
      });
    }

    async function streamLine(kind: string, text: string) {
      if (prefersReducedMotion()) {
        pushLine(kind, text);
        return;
      }
      const div = pushLine(kind, "");
      for (let i = 0; i < text.length; i++) {
        div.textContent = text.slice(0, i + 1);
        body.scrollTop = body.scrollHeight;
        // groups of multiple chars per tick for speed
        if (i % 3 !== 0) continue;
        await motionDelay(8);
      }
    }

    async function run(cmd: string) {
      busy = true;
      input.disabled = true;
      pushLine(cmd.startsWith("/") ? "cmd" : "you", cmd);
      const sc = pickScenario(cmd);
      for (const step of sc.steps) {
        await motionDelay(200);
        if (step.kind === "tool" && step.needsApproval) {
          const ok = await askApproval(step.text);
          if (!ok) {
            pushLine("error", "denied — skipping.");
            continue;
          }
        }
        if (step.kind === "tool") {
          await streamLine("tool", step.text);
        } else if (step.kind === "assistant") {
          await streamLine("assistant", step.text);
        } else {
          pushLine("out", step.text);
        }
      }
      busy = false;
      input.disabled = false;
      input.focus();
    }

    input.addEventListener("focus", () => {
      if (input.value === "" || input.value === "/") openMenu();
    });
    input.addEventListener("blur", () => setTimeout(closeMenu, 100));

    input.addEventListener("input", () => {
      const v = input.value;
      if (v === "" || v === "/") openMenu();
      else if (v.startsWith("/")) {
        // filter rows by prefix
        const q = v.toLowerCase();
        rows.forEach((r) => {
          const cmd = r.dataset.cmd!.toLowerCase();
          r.style.display = cmd.startsWith(q) ? "grid" : "none";
        });
        const visible = rows.filter((r) => r.style.display !== "none");
        sel = Math.min(sel, Math.max(0, visible.length - 1));
        if (visible.length === 0) closeMenu();
        else menu.classList.add("open");
        // paint sel within visible
        rows.forEach((r) => r.classList.remove("sel"));
        if (visible[sel]) visible[sel].classList.add("sel");
      } else {
        rows.forEach((r) => (r.style.display = "grid"));
        closeMenu();
      }
    });

    input.addEventListener("keydown", (e) => {
      const visible = rows.filter((r) => r.style.display !== "none");
      if (menu.classList.contains("open") && visible.length > 0) {
        if (e.key === "ArrowDown") {
          e.preventDefault();
          sel = (sel + 1) % visible.length;
          rows.forEach((r) => r.classList.remove("sel"));
          visible[sel].classList.add("sel");
          return;
        }
        if (e.key === "ArrowUp") {
          e.preventDefault();
          sel = (sel - 1 + visible.length) % visible.length;
          rows.forEach((r) => r.classList.remove("sel"));
          visible[sel].classList.add("sel");
          return;
        }
        if (e.key === "Escape") {
          e.preventDefault();
          closeMenu();
          return;
        }
        if (e.key === "Tab" || (e.key === "Enter" && (input.value === "" || input.value === "/"))) {
          e.preventDefault();
          input.value = visible[sel].dataset.cmd!;
          closeMenu();
          return;
        }
      }
      if (e.key === "Enter" && !busy) {
        const cmd = input.value.trim();
        if (!cmd) return;
        input.value = "";
        closeMenu();
        run(cmd);
      }
    });

    rows.forEach((r) =>
      r.addEventListener("mousedown", (e) => {
        e.preventDefault();
        input.value = r.dataset.cmd!;
        closeMenu();
        input.focus();
      })
    );

    paintMenuSel();
  });
</script>
