---
import ProductIcon from "./ProductIcon.astro";

interface Props {
  kind: "chat" | "code" | "cowork" | "design" | "agents" | "ship" | "claude";
}

const { kind } = Astro.props;
---

<div class="lesson-hero">
  <ProductIcon kind={kind} size={84} />
</div>

<style>
  .lesson-hero {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2.6rem 1rem;
    margin: 0.6rem 0 1.6rem;
    background-image: radial-gradient(circle at 1px 1px, var(--line) 1px, transparent 0);
    background-size: 18px 18px;
  }
</style>
