---
/**
 * Renders a screencast slot from src/data/videos.ts. See ADR-0009.
 *
 * mode="loop"        — silent autoplay loop. On prefers-reduced-motion
 *                      the poster is shown instead (no playback at all).
 * mode="walkthrough" — YouTube facade. The poster + play-button render
 *                      inline; YouTube's iframe + JS are only fetched
 *                      after the user explicitly clicks. WCAG 1.2.2 +
 *                      1.2.3 are enforced by the registry contract
 *                      (verify-videos.mjs blocks present walkthroughs
 *                      missing captionsVerified or transcript).
 *
 * Slots with status:"missing" render nothing.
 *
 * Reduced-motion correctness (loop): we deliberately omit the HTML
 * `autoplay` attribute and start playback from script only when
 * prefers-reduced-motion is *not* reduce. This avoids the race where
 * removing `autoplay` after the browser has already started playback
 * does nothing.
 */
import { getVideoSlot } from "../data/videos";

interface Props {
  slot: string;
}
const { slot } = Astro.props;
const v = getVideoSlot(slot);

const renderLoop =
  v && v.status === "present" && v.mode === "loop" && v.webm && v.mp4 && v.poster;

const renderWalkthrough =
  v &&
  v.status === "present" &&
  v.mode === "walkthrough" &&
  v.youtubeId &&
  v.transcript &&
  v.captionsVerified === true &&
  v.poster;
---

{
  renderLoop && (
    <figure class="screencast" style={`--aspect: ${v.aspect ?? "16 / 9"};`}>
      <video
        class="screencast-video"
        muted
        loop
        playsinline
        preload="metadata"
        poster={v.poster}
        aria-label={v.posterAlt}
        data-screencast-loop
      >
        <source src={v.webm} type="video/webm" />
        <source src={v.mp4} type="video/mp4" />
      </video>
    </figure>
  )
}

{
  renderWalkthrough && (
    <figure class="screencast" style={`--aspect: ${v.aspect ?? "16 / 9"};`}>
      <button
        type="button"
        class="screencast-facade"
        data-screencast-youtube={v.youtubeId}
        aria-label={`Play video: ${v.posterAlt}`}
      >
        <img class="screencast-poster" src={v.poster} alt="" loading="lazy" />
        <span class="screencast-play" aria-hidden="true">▶</span>
      </button>
      <details class="screencast-transcript">
        <summary>Transcript</summary>
        <div class="screencast-transcript-body">{v.transcript}</div>
      </details>
    </figure>
  )
}

<style>
  .screencast {
    margin: 1.5rem 0;
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  /* Loop fills the figure. Walkthrough lets transcript hang below. */
  .screencast > video.screencast-video {
    aspect-ratio: var(--aspect);
  }
  .screencast-video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .screencast-facade {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: var(--aspect);
    padding: 0;
    border: 0;
    background: var(--surface-2);
    cursor: pointer;
    overflow: hidden;
  }
  .screencast-poster {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .screencast-play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 2.5rem;
    color: #fff;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
    background: rgba(0, 0, 0, 0.18);
    transition: background 120ms ease;
  }
  .screencast-facade:hover .screencast-play,
  .screencast-facade:focus-visible .screencast-play {
    background: rgba(0, 0, 0, 0.32);
  }
  .screencast-iframe {
    display: block;
    width: 100%;
    aspect-ratio: var(--aspect);
    border: 0;
  }
  .screencast-transcript {
    border-top: 1px solid var(--line);
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
  }
  .screencast-transcript summary {
    cursor: pointer;
    font-weight: 600;
  }
  .screencast-transcript-body {
    margin-top: 0.5rem;
    white-space: pre-wrap;
    color: var(--ink-soft);
  }
</style>

<script>
  // Loop: start playback only for users who haven't opted out of motion.
  if (typeof window !== "undefined") {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!reduce) {
      for (const v of document.querySelectorAll<HTMLVideoElement>("[data-screencast-loop]")) {
        v.play().catch(() => {
          /* autoplay can be blocked; poster stays visible. */
        });
      }
    }
  }

  // Walkthrough: replace the facade button with an iframe on first click.
  // No YouTube network requests fire until that click — verified by the
  // empty network panel on initial page load.
  //
  // YouTube IDs are an exact 11-char [A-Za-z0-9_-] string. Anything else
  // is either a typo or an injection attempt; refuse the click.
  const YOUTUBE_ID = /^[\w-]{11}$/;
  for (const btn of document.querySelectorAll<HTMLButtonElement>(
    "[data-screencast-youtube]",
  )) {
    btn.addEventListener(
      "click",
      () => {
        const id = btn.getAttribute("data-screencast-youtube");
        if (!id || !YOUTUBE_ID.test(id)) return;
        const iframe = document.createElement("iframe");
        iframe.className = "screencast-iframe";
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
        iframe.title = btn.getAttribute("aria-label") ?? "Video walkthrough";
        iframe.allow =
          "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
        iframe.allowFullscreen = true;
        // Restrict the embedded origin's capabilities — YouTube needs
        // scripts + same-origin (for postMessage), presentation (for
        // fullscreen), and popup permission (for the "Watch on YouTube"
        // link). Nothing else.
        iframe.setAttribute(
          "sandbox",
          "allow-scripts allow-same-origin allow-presentation allow-popups allow-popups-to-escape-sandbox",
        );
        btn.replaceWith(iframe);
        // Move focus to the iframe *after* its document has loaded —
        // focusing a not-yet-ready browsing context silently fails
        // (WCAG 2.4.3 focus-order regression).
        iframe.addEventListener("load", () => iframe.focus(), { once: true });
      },
      { once: true },
    );
  }
</script>
