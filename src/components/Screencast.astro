---
/**
 * Renders a screencast slot from src/data/videos.ts. See ADR-0009.
 *
 * mode="loop"        — silent autoplay loop. Posters render on
 *                      prefers-reduced-motion. Implemented now.
 * mode="walkthrough" — YouTube facade. Lazy-loads iframe on click.
 *                      Implemented in #104.
 *
 * Slots with status:"missing" render nothing.
 */
import { getVideoSlot } from "../data/videos";

interface Props {
  slot: string;
}
const { slot } = Astro.props;
const v = getVideoSlot(slot);
const renderLoop =
  v && v.status === "present" && v.mode === "loop" && v.webm && v.mp4 && v.poster;
---

{
  renderLoop && (
    <figure class="screencast" style={`--aspect: ${v.aspect ?? "16 / 9"};`}>
      <video
        class="screencast-video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster={v.poster}
        aria-label={v.posterAlt}
      >
        <source src={v.webm} type="video/webm" />
        <source src={v.mp4} type="video/mp4" />
      </video>
    </figure>
  )
}

<style>
  .screencast {
    margin: 1.5rem 0;
    aspect-ratio: var(--aspect);
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .screencast-video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Reduced-motion users get the poster frame only — no autoplay. */
  @media (prefers-reduced-motion: reduce) {
    .screencast-video {
      animation: none;
    }
  }
</style>

<script>
  // Per ADR-0009: stop the autoplay loop for reduced-motion users.
  // We still render the poster (the `poster` attribute), but the
  // <video> would otherwise start playing on its own. Pause it.
  if (
    typeof window !== "undefined" &&
    window.matchMedia("(prefers-reduced-motion: reduce)").matches
  ) {
    for (const v of document.querySelectorAll<HTMLVideoElement>(".screencast-video")) {
      v.removeAttribute("autoplay");
      v.pause();
    }
  }
</script>
