---
/**
 * Renders a screencast slot from src/data/videos.ts. See ADR-0009.
 *
 * mode="loop"        — silent autoplay loop. On prefers-reduced-motion
 *                      the poster is shown instead (no playback at all).
 *                      Implemented now.
 * mode="walkthrough" — YouTube facade. Lazy-loads iframe on click.
 *                      Implemented in #104.
 *
 * Slots with status:"missing" render nothing.
 *
 * Reduced-motion correctness: we deliberately omit the HTML `autoplay`
 * attribute. A small inline script calls `.play()` only when
 * prefers-reduced-motion is *not* reduce. This avoids the race where
 * removing `autoplay` after the browser has already started playback
 * does nothing.
 */
import { getVideoSlot } from "../data/videos";

interface Props {
  slot: string;
}
const { slot } = Astro.props;
const v = getVideoSlot(slot);
const renderLoop =
  v && v.status === "present" && v.mode === "loop" && v.webm && v.mp4 && v.poster;
---

{
  renderLoop && (
    <figure class="screencast" style={`--aspect: ${v.aspect ?? "16 / 9"};`}>
      <video
        class="screencast-video"
        muted
        loop
        playsinline
        preload="metadata"
        poster={v.poster}
        aria-label={v.posterAlt}
        data-screencast-loop
      >
        <source src={v.webm} type="video/webm" />
        <source src={v.mp4} type="video/mp4" />
      </video>
    </figure>
  )
}

<style>
  .screencast {
    margin: 1.5rem 0;
    aspect-ratio: var(--aspect);
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .screencast-video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script>
  // No `autoplay` attribute is rendered. We start playback here, only
  // for users who haven't opted out of motion. Reduced-motion users
  // see the poster frame (the video's default before .play() is called).
  if (typeof window !== "undefined") {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!reduce) {
      for (const v of document.querySelectorAll<HTMLVideoElement>("[data-screencast-loop]")) {
        v.play().catch(() => {
          /* autoplay can be blocked; poster stays visible. */
        });
      }
    }
  }
</script>
