---
/**
 * JSON-LD LearningResource + BreadcrumbList schema for a lesson page.
 *
 * Helps search engines surface lessons in education-related results and
 * lets aggregators pick up the title, blurb, time-required, and curriculum.
 * Output is two inline <script type="application/ld+json"> blocks.
 */
import { trackById, type Lesson } from "../data/curriculum";

interface Props {
  lesson: Lesson;
  url: string;
}

const { lesson, url } = Astro.props;
const track = trackById(lesson.track);
const origin = new URL(url).origin;

const learningResource = {
  "@context": "https://schema.org",
  "@type": "LearningResource",
  name: lesson.title,
  description: lesson.blurb,
  url,
  inLanguage: "en",
  learningResourceType: "Tutorial",
  isAccessibleForFree: true,
  timeRequired: `PT${lesson.minutes}M`,
  educationalLevel: "Beginner",
  isPartOf: {
    "@type": "Course",
    name: "Learn AI",
    description: "A hands-on tour of modern AI assistants and agents.",
  },
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Curriculum", item: `${origin}/` },
    { "@type": "ListItem", position: 2, name: track.title, item: `${origin}/#track-${track.id}` },
    { "@type": "ListItem", position: 3, name: lesson.title, item: url },
  ],
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(learningResource)}></script>
<script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)}></script>
