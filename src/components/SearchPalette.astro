---
import { LESSONS, TRACKS } from "../data/curriculum";
import { STATIC_PAGES } from "../data/static-pages";
import SearchIcon from "./SearchIcon.astro";

type Entry = { kind: "lesson" | "page"; title: string; blurb: string; href: string; track?: string };

const trackMap = new Map(TRACKS.map((t) => [t.id, t.title]));

const entries: Entry[] = [
  ...LESSONS.map<Entry>((l) => ({
    kind: "lesson",
    title: l.title,
    blurb: l.blurb,
    href: `/lessons/${l.slug}`,
    track: trackMap.get(l.track),
  })),
  ...STATIC_PAGES.filter((p) => p.search).map<Entry>((p) => ({
    kind: "page",
    title: p.title,
    blurb: p.blurb,
    href: p.href,
  })),
];

const indexJSON: string = JSON.stringify(entries);
---

<button type="button" class="search-trigger" data-ui-action="open-search" aria-label="Search (⌘K)" title="Search (⌘K)">
  <SearchIcon size={15} />
</button>

<!-- Native <dialog>: UA stylesheet handles show/hide. Closed = display:none. -->
<dialog class="search-dialog" data-search-dialog aria-label="Search">
  <form method="dialog" class="search-input-row">
    <SearchIcon class="search-icon" />
    <input
      type="text"
      aria-label="Search lessons and pages"
      placeholder="Search lessons and pages…"
      data-search-input
      autocomplete="off"
      spellcheck="false"
    />
    <button type="button" class="search-close" data-ui-action="close-search" aria-label="Close search">
      <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
        <line x1="3" y1="3" x2="11" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="11" y1="3" x2="3" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </form>
  <ul class="search-results" data-search-results></ul>
  <script id="search-index" type="application/json" set:html={indexJSON} />
  <div class="search-foot">
    <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
    <span><kbd>Enter</kbd> open</span>
    <span><kbd>Esc</kbd> close</span>
    <span style="margin-left: auto;">Open with <kbd>⌘</kbd><kbd>K</kbd> or <kbd>/</kbd></span>
  </div>
</dialog>

<style>
  .search-trigger {
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    color: var(--ink-faint);
    padding: 0.3rem 0.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    line-height: 0;
  }
  .search-trigger:hover {
    background: var(--surface-2);
    color: var(--ink);
    border-color: var(--line);
  }

  /* Native <dialog>: closed by default; opens via .showModal(). UA stylesheet
     handles the closed = display:none state — no [hidden]-vs-display traps. */
  .search-dialog {
    margin: 8vh auto auto;
    padding: 0;
    width: min(640px, calc(100% - 2rem));
    max-height: 80vh;
    background: var(--surface);
    color: var(--ink);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.25);
    overflow: hidden;
  }
  .search-dialog[open] {
    animation: pop-in 0.18s cubic-bezier(.34,1.36,.64,1);
  }
  .search-dialog::backdrop {
    background: rgba(0, 0, 0, 0.4);
    animation: fade-in 0.12s ease;
  }
  @keyframes pop-in {
    from { opacity: 0; transform: translateY(-8px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  .search-input-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--line);
    margin: 0;
  }
  .search-icon { color: var(--ink-faint); flex-shrink: 0; }
  .search-input-row input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    color: var(--ink);
    font: inherit;
    font-size: 1rem;
  }
  .search-input-row input::placeholder { color: var(--ink-faint); }
  .search-close {
    background: transparent;
    border: 1px solid transparent;
    color: var(--ink-faint);
    border-radius: var(--radius-sm);
    width: 26px;
    height: 26px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    flex-shrink: 0;
  }
  .search-close:hover {
    background: var(--surface-2);
    color: var(--ink);
    border-color: var(--line);
  }
  .search-results {
    list-style: none;
    margin: 0;
    padding: 0.3rem;
    max-height: 50vh;
    overflow-y: auto;
  }
  .search-results li {
    padding: 0.55rem 0.7rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .search-results li.sel { background: var(--surface-2); }
  .search-results li.group-header {
    padding: 0.6rem 0.7rem 0.2rem;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
    cursor: default;
    background: transparent;
  }
  .search-results li.group-header:hover { background: transparent; }
  .search-results .row { display: flex; align-items: baseline; gap: 0.55rem; }
  .search-results .title { font-weight: 500; color: var(--ink); font-size: 0.94rem; }
  .search-results .pill {
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-faint);
    border: 1px solid var(--line);
    padding: 0.05rem 0.4rem;
    border-radius: 4px;
  }
  .search-results .blurb { font-size: 0.82rem; color: var(--ink-soft); line-height: 1.4; }
  .search-results .empty { padding: 1.2rem; color: var(--ink-faint); text-align: center; font-size: 0.9rem; }
  .search-foot {
    display: flex;
    gap: 1rem;
    padding: 0.55rem 1rem;
    border-top: 1px solid var(--line);
    background: var(--bg);
    font-size: 0.74rem;
    color: var(--ink-faint);
  }
  .search-foot kbd,
  .search-input-row kbd {
    background: var(--surface-2);
    border: 1px solid var(--line);
    color: var(--ink-soft);
    font-family: var(--mono);
    font-size: 0.7rem;
    padding: 0.05rem 0.35rem;
    border-radius: 4px;
  }
</style>

<script>
  // Search-results rendering only. Dialog open/close + ⌘K + backdrop-click
  // are owned by src/scripts/ui.ts (single owner per interaction).

  type Entry = { kind: "lesson" | "page"; title: string; blurb: string; href: string; track?: string };
  const INDEX: Entry[] = JSON.parse(
    document.getElementById("search-index")?.textContent ?? "[]",
  ) as Entry[];

  function score(q: string, e: Entry): number {
    const ql = q.toLowerCase();
    const hay = (e.title + " " + e.blurb + " " + (e.track ?? "")).toLowerCase();
    if (!ql) return 0;
    if (e.title.toLowerCase() === ql) return 1000;
    if (e.title.toLowerCase().startsWith(ql)) return 800;
    if (e.title.toLowerCase().includes(ql)) return 600;
    const tokens = ql.split(/\s+/).filter(Boolean);
    if (tokens.every((t) => hay.includes(t))) return 400;
    return 0;
  }

  function search(q: string): Entry[] {
    if (!q.trim()) return INDEX;
    return INDEX
      .map((e) => ({ e, s: score(q, e) }))
      .filter((x) => x.s > 0)
      .sort((a, b) => b.s - a.s)
      .map((x) => x.e)
      .slice(0, 10);
  }

  function escapeHTML(text: string): string {
    return text.replace(/[&<>"']/g, (c) =>
      ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c] as string,
    );
  }

  function highlight(text: string, q: string): string {
    const tokens = q.toLowerCase().split(/\s+/).filter(Boolean);
    if (tokens.length === 0) return escapeHTML(text);
    const re = new RegExp(tokens.map((t) => t.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")).join("|"), "ig");
    let out = "";
    let last = 0;
    for (const match of text.matchAll(re)) {
      const start = match.index ?? 0;
      out += escapeHTML(text.slice(last, start));
      out += `<mark>${escapeHTML(match[0])}</mark>`;
      last = start + match[0].length;
    }
    out += escapeHTML(text.slice(last));
    return out;
  }

  // These elements are always rendered with this script — no defensive guard.
  const dialog = document.querySelector<HTMLDialogElement>("[data-search-dialog]")!;
  const input = document.querySelector<HTMLInputElement>("[data-search-input]")!;
  const list = document.querySelector<HTMLUListElement>("[data-search-results]")!;

  let cur: Entry[] = [];
  let sel = 0;

  function paintSel() {
    for (const l of list.querySelectorAll<HTMLLIElement>("li[data-result-index]")) {
      l.classList.toggle("sel", Number(l.dataset.resultIndex) === sel);
    }
  }

  function render() {
    cur = search(input.value);
    list.innerHTML = "";
    if (cur.length === 0) {
      const li = document.createElement("li");
      li.className = "empty";
      li.textContent = "No matches. Try a different word.";
      list.appendChild(li);
      return;
    }
    const q = input.value;
    const showGroups = !q.trim();
    let lastGroup = "";
    cur.forEach((e, i) => {
      const group = e.kind === "lesson" ? (e.track ?? "Lesson") : "Pages";
      if (showGroups && group !== lastGroup) {
        const h = document.createElement("li");
        h.className = "group-header";
        h.textContent = group;
        list.appendChild(h);
        lastGroup = group;
      }
      const li = document.createElement("li");
      li.dataset.resultIndex = String(i);
      if (i === sel) li.classList.add("sel");
      li.innerHTML = `
        <div class="row">
          <span class="title">${highlight(e.title, q)}</span>
          ${showGroups ? "" : `<span class="pill">${e.kind === "lesson" ? (e.track ?? "Lesson") : "Page"}</span>`}
        </div>
        <div class="blurb">${highlight(e.blurb, q)}</div>
      `;
      li.addEventListener("click", () => navigate(e));
      li.addEventListener("mouseenter", () => {
        sel = i;
        paintSel();
      });
      list.appendChild(li);
    });
  }

  function navigate(e: Entry) {
    dialog.close();
    window.location.href = e.href;
  }

  // Hook ui.ts's openSearch() into our render reset.
  (window as Window & { __searchRender?: () => void }).__searchRender = () => {
    sel = 0;
    input.value = "";
    render();
    setTimeout(() => input.focus(), 0);
  };

  input.addEventListener("input", () => {
    sel = 0;
    render();
  });

  // Result-list keyboard nav. Dialog handles Esc natively; ui.ts handles ⌘K.
  dialog.addEventListener("keydown", (e) => {
    if (e.key === "ArrowDown") {
      e.preventDefault();
      sel = Math.min(cur.length - 1, sel + 1);
      paintSel();
      list.querySelector("li.sel")?.scrollIntoView({ block: "nearest" });
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      sel = Math.max(0, sel - 1);
      paintSel();
      list.querySelector("li.sel")?.scrollIntoView({ block: "nearest" });
    } else if (e.key === "Enter") {
      e.preventDefault();
      if (cur[sel]) navigate(cur[sel]);
    }
  });
</script>
