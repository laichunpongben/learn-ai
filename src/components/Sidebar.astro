---
import { TRACKS, lessonsInTrack } from "../data/curriculum";

interface Props {
  currentId?: string;
}
const { currentId } = Astro.props;
---

<aside class="sidebar" data-sidebar aria-label="Curriculum">
  <nav aria-label="All lessons">
    <a href="/" class={`side-home ${currentId ? "" : "active"}`}>Curriculum</a>
    {TRACKS.map((t) => (
      <div class="side-group">
        <div class="side-group-title">{t.title}</div>
        <ul>
          {lessonsInTrack(t.id).map((l) => (
            <li>
              <a
                href={`/lessons/${l.slug}`}
                class={`side-link ${l.id === currentId ? "active" : ""}`}
                data-lesson-link
                data-lesson-id={l.id}
              >
                <span class="dot" data-side-dot></span>
                <span class="label">{l.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
    <div class="side-group">
      <div class="side-group-title">Reference</div>
      <ul>
        <li>
          <a href="/cookbook" class={`side-link ${currentId === "cookbook" ? "active" : ""}`}>
            <span class="dot"></span>
            <span class="label">Cookbook</span>
          </a>
        </li>
        <li>
          <a href="/glossary" class={`side-link ${currentId === "glossary" ? "active" : ""}`}>
            <span class="dot"></span>
            <span class="label">Glossary</span>
          </a>
        </li>
      </ul>
    </div>
  </nav>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 56px;
    align-self: start;
    max-height: calc(100vh - 56px);
    overflow-y: auto;
    padding: 1.4rem 0.6rem 2rem 0;
    border-right: 1px solid var(--line);
  }
  .sidebar nav {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .side-home {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.3rem 0.7rem;
    border: none;
  }
  .side-home:hover { color: var(--ink); border: none; }
  .side-home.active { color: var(--ink); }
  .side-group { display: flex; flex-direction: column; gap: 0.15rem; }
  .side-group-title {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.15rem 0.7rem;
    margin-top: 0.4rem;
  }
  .side-group ul { list-style: none; padding: 0; margin: 0; }
  .side-group li { margin: 0; }
  .side-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-sm);
    color: var(--ink-soft);
    font-size: 0.84rem;
    border: none;
    border-left: 2px solid transparent;
    padding-left: 0.55rem;
    line-height: 1.35;
  }
  .side-link:hover {
    background: var(--surface);
    color: var(--ink);
    border: none;
    border-left: 2px solid transparent;
  }
  .side-link.active {
    color: var(--ink);
    background: var(--surface);
    border-left-color: var(--accent);
    font-weight: 500;
  }
  .side-link .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--line-strong);
    flex-shrink: 0;
  }
  .side-link.done .dot { background: var(--good); }
  .side-link.active .dot { background: var(--accent); }
  .side-link .label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  @media (max-width: 960px) {
    .sidebar {
      position: fixed;
      top: 56px;
      bottom: 0;
      left: 0;
      width: 280px;
      max-width: 86vw;
      background: var(--bg);
      border-right: 1px solid var(--line);
      z-index: 30;
      transform: translateX(-100%);
      transition: transform 0.22s ease;
      padding: 1.2rem 0.6rem 2rem 0;
      max-height: none;
      overflow-y: auto;
    }
    :global(html.sidebar-open) .sidebar {
      transform: translateX(0);
    }
  }
</style>

<script>
  import { getDone } from "../scripts/progress";

  function paint() {
    const done = new Set(getDone());
    for (const a of document.querySelectorAll<HTMLAnchorElement>("[data-lesson-link]")) {
      a.classList.toggle("done", !!a.dataset.lessonId && done.has(a.dataset.lessonId));
    }
  }
  window.addEventListener("ct:progress", paint);
  paint();
</script>
