---
import { neighbors, trackById, type Lesson } from "../data/curriculum";
import NextPrev from "./NextPrev.astro";
import MarkDone from "./MarkDone.astro";
import LessonSchema from "./LessonSchema.astro";
import TocRail from "./TocRail.astro";

interface Props {
  lesson: Lesson;
}

const { lesson } = Astro.props;
const track = trackById(lesson.track);
const { prev, next } = neighbors(lesson.id);
const url = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
---

<LessonSchema lesson={lesson} url={url} />

<div class="lesson-layout">
  <article data-lesson-id={lesson.id}>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Curriculum</a></li>
        <li><a href={`/#track-${track.id}`}>{track.title}</a></li>
        <li aria-current="page">{lesson.title}</li>
      </ol>
    </nav>
    <p class="lesson-meta"><span class="tiny-link">{lesson.minutes} min</span></p>
    <h1>{lesson.title}</h1>
    <p class="lede">{lesson.blurb}</p>

    <slot />

    <MarkDone id={lesson.id} />
    <NextPrev prev={prev} next={next} />
  </article>
  <TocRail />
</div>

<style>
  .lesson-layout {
    display: flex;
    gap: 0;
    align-items: flex-start;
  }
  .lesson-layout article {
    flex: 1;
    min-width: 0;
  }
  @media (max-width: 1279px) {
    .lesson-layout { display: block; }
  }
  .breadcrumbs { margin: 0 0 0.4rem; }
  .breadcrumbs ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    font-size: 0.78rem;
    color: var(--ink-faint);
  }
  .breadcrumbs li + li::before {
    content: "›";
    margin-right: 0.3rem;
    color: var(--ink-faint);
  }
  .breadcrumbs a {
    color: var(--ink-soft);
    border-bottom: none;
  }
  .breadcrumbs a:hover { color: var(--ink); }
  .breadcrumbs li[aria-current="page"] { color: var(--ink); }
  .lesson-meta { margin: 0 0 1rem; }
</style>

<script>
  import { setLastVisited } from "../scripts/progress";
  const id = document.querySelector<HTMLElement>("article[data-lesson-id]")?.dataset.lessonId;
  if (id) setLastVisited(id);
</script>
