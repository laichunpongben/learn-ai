---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <nav class="footer-nav" aria-label="Site links">
    <a href="/">Curriculum</a>
    <a href="/cookbook">Cookbook</a>
    <a href="/glossary">Glossary</a>
    <a href="/rss.xml">RSS</a>
    <a href="/llms.txt">llms.txt</a>
  </nav>
  <p class="footer-line">
    © {year} Learn AI · part of <a class="ft-home" href="https://databookman.com">databookman.com</a>
  </p>
</footer>

<style>
  .site-footer {
    display: flex; flex-direction: column; gap: 1rem; align-items: center;
    border-top: 1px solid var(--line); margin-top: 5rem;
    padding: 2.5rem 1.5rem 2.25rem;
    color: var(--ink-faint); background: var(--surface);
  }
  @media (min-width: 720px) {
    .site-footer { flex-direction: row; justify-content: space-between;
      padding: 2rem clamp(2rem, 4vw, 4rem); }
  }
  .footer-nav { display: flex; gap: 1.4rem; flex-wrap: wrap; justify-content: center; }
  .footer-nav a { color: var(--ink-soft); border-bottom: none; font-size: 0.85rem; transition: color 0.18s ease; }
  .footer-nav a:hover { color: var(--ink); }
  .footer-line { margin: 0; font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; text-align: center; }
  .ft-home { text-transform: none; letter-spacing: 0; color: var(--ink-soft); border-bottom: 1px solid var(--line-strong); }
  .ft-home:hover { color: var(--ink); border-bottom-color: var(--ink); }
</style>
