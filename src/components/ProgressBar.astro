---
import { LESSONS } from "../data/curriculum";

const total = LESSONS.length;
const totalMinutes = LESSONS.reduce((s, l) => s + l.minutes, 0);

// id → minutes lookup, embedded as JSON so the module script can compute remaining
// time without re-importing the curriculum (which would pull all lesson data into
// the client bundle).
const minutesById: Record<string, number> = Object.fromEntries(
  LESSONS.map((l) => [l.id, l.minutes]),
);
const minutesJSON = JSON.stringify(minutesById);
---

<div data-progress data-total={total} data-total-minutes={totalMinutes}>
  <div class="progress-bar"><span data-progress-fill style="width: 0%"></span></div>
  <div class="progress-meta">
    <span>
      <strong data-progress-count>0</strong> of {total} lessons ·
      <strong data-progress-remaining>{totalMinutes}</strong> min remaining
    </span>
    <button class="ghost" data-reset>Reset progress</button>
  </div>
  <script type="application/json" data-minutes set:html={minutesJSON} />
</div>

<script>
  import { getDone, reset } from "../scripts/progress";

  const minutesById: Record<string, number> = JSON.parse(
    document.querySelector("[data-minutes]")?.textContent ?? "{}",
  );

  function paint() {
    const done = getDone();
    const n = done.length;
    const doneMinutes = done.reduce((s, id) => s + (minutesById[id] || 0), 0);
    for (const root of document.querySelectorAll<HTMLElement>("[data-progress]")) {
      const total = Number(root.dataset.total ?? 0);
      const totalMin = Number(root.dataset.totalMinutes ?? 0);
      const fill = root.querySelector<HTMLElement>("[data-progress-fill]");
      const count = root.querySelector<HTMLElement>("[data-progress-count]");
      const rem = root.querySelector<HTMLElement>("[data-progress-remaining]");
      if (fill) fill.style.width = `${total ? (n / total) * 100 : 0}%`;
      if (count) count.textContent = String(n);
      if (rem) rem.textContent = String(totalMin - doneMinutes);
    }
  }

  for (const btn of document.querySelectorAll<HTMLButtonElement>("[data-reset]")) {
    btn.addEventListener("click", () => {
      if (confirm("Reset progress and start fresh? This only clears your browser — nothing is sent anywhere.")) {
        reset();
      }
    });
  }

  window.addEventListener("ct:progress", paint);
  paint();
</script>
