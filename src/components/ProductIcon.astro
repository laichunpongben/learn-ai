---
/**
 * Inline SVG marks for each product. Monochrome, minimal, scale to size.
 * Designed at 64×48 and scaled with viewBox.
 */
type Kind = "chat" | "code" | "cowork" | "design" | "agents" | "ship" | "claude";

interface Props {
  kind: Kind;
  size?: number;
  label?: string;
}

const { kind, size = 56, label } = Astro.props;
const aria = label ?? `${kind} product icon`;
---

{kind === "chat" && (
  <svg width={size} height={(size * 48) / 64} viewBox="0 0 64 48" role="img" aria-label={aria} class="pi">
    <rect x="2" y="2" width="44" height="32" rx="6" />
    <rect x="14" y="22" width="44" height="20" rx="6" class="b" />
    <line x1="10" y1="12" x2="38" y2="12" />
    <line x1="10" y1="20" x2="30" y2="20" />
    <line x1="22" y1="30" x2="50" y2="30" class="b" />
    <line x1="22" y1="36" x2="42" y2="36" class="b" />
  </svg>
)}

{kind === "code" && (
  <svg width={size} height={(size * 48) / 64} viewBox="0 0 64 48" role="img" aria-label={aria} class="pi">
    <rect x="2" y="2" width="60" height="44" rx="4" />
    <circle cx="8" cy="8" r="1.5" class="fill" />
    <circle cx="13" cy="8" r="1.5" class="fill" />
    <circle cx="18" cy="8" r="1.5" class="fill" />
    <line x1="2" y1="14" x2="62" y2="14" />
    <text x="8" y="28" class="t" font-family="monospace" font-size="6">›</text>
    <line x1="14" y1="26" x2="36" y2="26" />
    <line x1="8" y1="36" x2="28" y2="36" />
  </svg>
)}

{kind === "cowork" && (
  <svg width={size} height={(size * 48) / 64} viewBox="0 0 64 48" role="img" aria-label={aria} class="pi">
    <rect x="2" y="6" width="28" height="10" rx="2" />
    <rect x="2" y="20" width="28" height="10" rx="2" />
    <rect x="2" y="34" width="28" height="10" rx="2" />
    <line x1="6" y1="11" x2="22" y2="11" />
    <line x1="6" y1="25" x2="22" y2="25" />
    <line x1="6" y1="39" x2="18" y2="39" />
    <rect x="36" y="14" width="26" height="22" rx="2" class="b" />
    <line x1="40" y1="20" x2="58" y2="20" class="b" />
    <line x1="40" y1="25" x2="54" y2="25" class="b" />
    <line x1="40" y1="30" x2="56" y2="30" class="b" />
  </svg>
)}

{kind === "design" && (
  <svg width={size} height={(size * 48) / 64} viewBox="0 0 64 48" role="img" aria-label={aria} class="pi">
    <rect x="2" y="4" width="60" height="40" rx="4" />
    <line x1="2" y1="12" x2="62" y2="12" />
    <circle cx="7" cy="8" r="1.2" class="fill" />
    <circle cx="11" cy="8" r="1.2" class="fill" />
    <circle cx="15" cy="8" r="1.2" class="fill" />
    <rect x="8" y="18" width="20" height="18" rx="2" class="b" />
    <rect x="32" y="18" width="24" height="8" rx="2" class="b" />
    <rect x="32" y="30" width="24" height="6" rx="2" class="b" />
  </svg>
)}

{kind === "agents" && (
  <svg width={size} height={(size * 48) / 64} viewBox="0 0 64 48" role="img" aria-label={aria} class="pi">
    <circle cx="32" cy="24" r="6" />
    <circle cx="10" cy="10" r="4" class="b" />
    <circle cx="54" cy="10" r="4" class="b" />
    <circle cx="10" cy="38" r="4" class="b" />
    <circle cx="54" cy="38" r="4" class="b" />
    <line x1="14" y1="13" x2="27" y2="21" />
    <line x1="50" y1="13" x2="37" y2="21" />
    <line x1="14" y1="35" x2="27" y2="27" />
    <line x1="50" y1="35" x2="37" y2="27" />
  </svg>
)}

{kind === "ship" && (
  <svg width={size} height={(size * 48) / 64} viewBox="0 0 64 48" role="img" aria-label={aria} class="pi">
    <path d="M8 40 L 32 8 L 56 40" />
    <path d="M20 28 L 32 16 L 44 28" class="b" />
    <line x1="32" y1="16" x2="32" y2="40" class="b" />
  </svg>
)}

{kind === "claude" && (
  <svg width={size} height={size} viewBox="0 0 64 64" role="img" aria-label={aria} class="pi">
    <circle cx="32" cy="32" r="22" />
    <circle cx="32" cy="32" r="10" class="fill-accent" />
  </svg>
)}

<style>
  .pi {
    stroke: currentColor;
    stroke-width: 1.5;
    fill: none;
    color: var(--ink);
  }
  .pi .b { stroke: var(--ink-faint); stroke-width: 1.25; }
  .pi .fill { fill: currentColor; stroke: none; }
  .pi .fill-accent { fill: var(--accent); stroke: none; }
  .pi .t { fill: var(--accent); stroke: none; }
</style>
