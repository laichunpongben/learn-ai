---
interface Props {
  id: string;
}
const { id } = Astro.props;
---

<div class="mark-done" data-mark-done data-lesson-id={id}>
  <button class="accent" data-toggle>Mark this lesson as done</button>
  <span class="status" data-status></span>
</div>

<script>
  import { isDone, markDone, markUndone } from "../scripts/progress";

  function paint(root: HTMLElement, id: string) {
    const done = isDone(id);
    const btn = root.querySelector<HTMLButtonElement>("[data-toggle]");
    const status = root.querySelector<HTMLElement>("[data-status]");
    if (!btn || !status) return;
    btn.textContent = done ? "Unmark" : "Mark this lesson as done";
    btn.classList.toggle("accent", !done);
    btn.classList.toggle("ghost", done);
    status.textContent = done
      ? "Done. Move on whenever you're ready."
      : "No pressure — read at your own pace.";
    status.classList.toggle("done", done);
  }

  for (const root of document.querySelectorAll<HTMLElement>("[data-mark-done]")) {
    const id = root.dataset.lessonId;
    if (!id) continue;
    paint(root, id);
    root.querySelector<HTMLButtonElement>("[data-toggle]")?.addEventListener("click", () => {
      (isDone(id) ? markUndone : markDone)(id);
      paint(root, id);
    });
  }
</script>
