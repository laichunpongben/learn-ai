---
import Layout from "../layouts/Layout.astro";
import ProgressBar from "../components/ProgressBar.astro";
import LessonCard from "../components/LessonCard.astro";
import ProductRow from "../components/ProductRow.astro";
import { TRACKS, lessonsInTrack } from "../data/curriculum";
---

<Layout title="Learn AI">
  <main>
    <h1>A hands-on tour of AI assistants</h1>
    <p class="lede">
      Drive imitations of every kind of modern AI tool — chat, coding CLI, cloud agent, UI generator,
      self-hosted agent. End with a tool you built.
    </p>

    <ProductRow />

    <div class="card" style="padding: 0.9rem 1rem;">
      <ProgressBar />
      <div id="continue" style="margin-top: 0.7rem;"></div>
    </div>

    {
      TRACKS.map((t) => {
        const lessons = lessonsInTrack(t.id);
        return (
          <section class="track-section" id={`track-${t.id}`}>
            <div class="track-header">
              <h2>{t.title}</h2>
              <span class="tagline">{t.tagline}</span>
              <span class="track-count" data-track-count={t.id}>0 / {lessons.length}</span>
            </div>
            <div class="lesson-grid">
              {lessons.map((l) => (
                <LessonCard lesson={l} />
              ))}
            </div>
          </section>
        );
      })
    }
  </main>
</Layout>

<script>
  const KEY = "learn-ai.progress.v1";
  type Progress = { done: string[]; lastVisited?: string };

  function read(): Progress {
    try {
      const raw = localStorage.getItem(KEY);
      if (!raw) return { done: [] };
      const parsed = JSON.parse(raw);
      if (!Array.isArray(parsed.done)) return { done: [] };
      return parsed;
    } catch {
      return { done: [] };
    }
  }

  function paintCards() {
    const doneSet = new Set(read().done);
    const doneByTrack: Record<string, number> = {};
    const totalByTrack: Record<string, number> = {};
    document.querySelectorAll<HTMLAnchorElement>("[data-lesson-card]").forEach((el) => {
      const id = el.dataset.lessonId!;
      const track = el.dataset.lessonTrack ?? "";
      totalByTrack[track] = (totalByTrack[track] ?? 0) + 1;
      const done = doneSet.has(id);
      el.classList.toggle("done", done);
      if (done) doneByTrack[track] = (doneByTrack[track] ?? 0) + 1;
    });
    document.querySelectorAll<HTMLElement>("[data-track-count]").forEach((el) => {
      const track = el.dataset.trackCount!;
      const d = doneByTrack[track] ?? 0;
      const t = totalByTrack[track] ?? 0;
      el.textContent = `${d} / ${t}`;
      el.classList.toggle("track-count-done", t > 0 && d === t);
    });
  }

  function paintContinue() {
    const cur = read();
    const c = document.getElementById("continue");
    if (!c) return;
    if (cur.done.length === 0 && !cur.lastVisited) {
      c.innerHTML = '<a class="button" href="/lessons/welcome">Start the tour →</a>';
      return;
    }
    const firstUndone = LESSONS_IDS.find((id) => !cur.done.includes(id));
    const target = firstUndone ?? cur.lastVisited;
    if (!target) {
      c.innerHTML = '<span class="tiny-link">All done. Reset above to replay.</span>';
      return;
    }
    const slug = LESSON_SLUGS[target] ?? "welcome";
    const label = firstUndone ? "Continue →" : "Revisit last lesson →";
    c.innerHTML = `<a class="button" href="/lessons/${slug}">${label}</a>`;
  }

  const LESSONS_IDS: string[] = [];
  const LESSON_SLUGS: Record<string, string> = {};
  document.querySelectorAll<HTMLAnchorElement>("[data-lesson-card]").forEach((el) => {
    const id = el.dataset.lessonId!;
    LESSONS_IDS.push(id);
    const slug = el.getAttribute("href")!.replace("/lessons/", "");
    LESSON_SLUGS[id] = slug;
  });

  window.addEventListener("ct:progress", () => { paintCards(); paintContinue(); });
  paintCards();
  paintContinue();
</script>
