---
import Layout from "../../layouts/Layout.astro";
import LessonShell from "../../components/LessonShell.astro";
import { LESSONS } from "../../data/curriculum";

const lesson = LESSONS.find((l) => l.id === "chat-projects")!;
---

<Layout title={`${lesson.title} · Learn AI`} description={lesson.blurb} currentId="chat-projects">
    <LessonShell lesson={lesson} hero="chat">
      <p>
        Every major chat app has a way to <strong>create a custom assistant</strong> — a folder of related
        chats with shared files and instructions. Different names, same idea.
      </p>

      <table>
        <thead>
          <tr><th>App</th><th>Feature name</th><th>Shareable</th></tr>
        </thead>
        <tbody>
          <tr><td>ChatGPT</td><td>Projects, Custom GPTs</td><td>Yes (GPT Store)</td></tr>
          <tr><td>Claude.ai</td><td>Projects</td><td>Team plans only</td></tr>
          <tr><td>Gemini</td><td>Gems</td><td>Yes</td></tr>
          <tr><td>Perplexity</td><td>Spaces</td><td>Yes</td></tr>
          <tr><td>Mistral Le Chat</td><td>Agents</td><td>Yes</td></tr>
        </tbody>
      </table>

      <h2>The shared anatomy</h2>
      <div class="proj-anatomy">
        <div class="row"><strong>Custom instructions</strong><span>System prompt prepended to every chat inside</span></div>
        <div class="row"><strong>Knowledge files</strong><span>Documents uploaded once, referenced always</span></div>
        <div class="row"><strong>Chats</strong><span>Each conversation saved and named</span></div>
      </div>

      <h2>When to make one</h2>
      <ul>
        <li><strong>Work projects.</strong> "Q4 launch" — brief + brand + spec attached.</li>
        <li><strong>Hobbies.</strong> "Sourdough", "Italy trip", "Mom's eulogy".</li>
        <li><strong>Studies.</strong> "Linear algebra" with lecture notes.</li>
      </ul>

      <div class="callout">
        <strong>Mental model.</strong> Plain chat = a conversation with a smart stranger.
        Custom assistant = a conversation with someone who already read your briefing pack.
      </div>
    </LessonShell>
</Layout>

<style>
  .proj-anatomy {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    margin: 1rem 0 1.5rem;
    overflow: hidden;
  }
  .proj-anatomy .row {
    display: grid;
    grid-template-columns: 220px 1fr;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--line);
    background: var(--surface);
    font-size: 0.92rem;
  }
  .proj-anatomy .row:last-child { border-bottom: none; }
  .proj-anatomy .row span { color: var(--ink-soft); }
  @media (max-width: 600px) {
    .proj-anatomy .row { grid-template-columns: 1fr; gap: 0.2rem; }
  }
</style>
