---
import Layout from "../../layouts/Layout.astro";
import LessonShell from "../../components/LessonShell.astro";
import { LESSONS } from "../../data/curriculum";

const lesson = LESSONS.find((l) => l.id === "cowork-what")!;
---

<Layout title={`${lesson.title} · Learn AI`} description={lesson.blurb} currentId="cowork-what">
  <main>
    <LessonShell lesson={lesson} hero="cowork">
      <p>
        <strong>Cloud agents</strong> run tasks in their own sandboxes, in parallel, in the background.
        You submit, step away, come back to diffs / pull requests.
      </p>

      <table>
        <thead>
          <tr><th>Product</th><th>From</th><th>What it's good at</th></tr>
        </thead>
        <tbody>
          <tr><td>Devin</td><td>Cognition</td><td>Autonomous engineer over a whole repo</td></tr>
          <tr><td>Claude Cowork</td><td>Anthropic</td><td>Many small tasks across one or more repos</td></tr>
          <tr><td>Copilot Workspace</td><td>GitHub</td><td>Issue → PR with task plan</td></tr>
          <tr><td>Codex Cloud</td><td>OpenAI</td><td>Background coding with PR review</td></tr>
          <tr><td>OpenHands (cloud)</td><td>All Hands AI</td><td>Open-source alternative, self-hostable</td></tr>
        </tbody>
      </table>

      <div class="vs">
        <div>
          <h3>Coding CLI</h3>
          <p>Pair programming. You and the agent on the same thing, together, in real time.</p>
        </div>
        <div class="arrow">→</div>
        <div>
          <h3>Cloud agent</h3>
          <p>Delegation. Many tasks in parallel sandboxes. You review when convenient.</p>
        </div>
      </div>

      <h2>Best for</h2>
      <ul>
        <li>Small features, bug fixes, dependency bumps</li>
        <li>Refactors with a clear before/after</li>
        <li>Documentation passes, test additions</li>
      </ul>

      <h2>Not for</h2>
      <ul>
        <li>"Design this product" — ambiguous, open-ended work</li>
        <li>Architectural debates that need conversation</li>
      </ul>
    </LessonShell>
  </main>
</Layout>

<style>
  .vs {
    display: grid;
    grid-template-columns: 1fr 40px 1fr;
    gap: 0.5rem;
    align-items: stretch;
    margin: 1.4rem 0 1.6rem;
  }
  .vs > div:not(.arrow) {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.9rem 1rem;
  }
  .vs h3 { margin: 0 0 0.3rem; font-size: 0.95rem; }
  .vs p { margin: 0; color: var(--ink-soft); font-size: 0.88rem; }
  .vs .arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-faint);
    font-size: 1.4rem;
  }
  @media (max-width: 600px) {
    .vs { grid-template-columns: 1fr; }
    .vs .arrow { transform: rotate(90deg); margin: -0.3rem auto; }
  }
</style>
