---
import Layout from "../../layouts/Layout.astro";
import LessonShell from "../../components/LessonShell.astro";
import ProductIcon from "../../components/ProductIcon.astro";
import { LESSONS } from "../../data/curriculum";

const lesson = LESSONS.find((l) => l.id === "ship-it")!;

const paths = [
  {
    kind: "chat" as const,
    href: "/lessons/build-writing",
    title: "A · Writing assistant",
    desc: "Build a saved Project / Custom GPT / Gem you'll use whenever you need to draft writing.",
    time: "~10 min · no install",
  },
  {
    kind: "design" as const,
    href: "/lessons/build-webpage",
    title: "B · Live webpage",
    desc: "A working one-page website (portfolio, event invite, calculator) you can share.",
    time: "~15 min · no install",
  },
  {
    kind: "code" as const,
    href: "/lessons/build-script",
    title: "C · Personal script",
    desc: "A tiny CLI tool on your machine — rename photos by EXIF date — via a coding CLI.",
    time: "~20 min · coding CLI required",
  },
];
---

<Layout title={`${lesson.title} · Learn AI`} currentId="ship-it">
  <main>
    <LessonShell lesson={lesson} hero="ship">
      <p>
        Three paths, all ending with a tool you actually keep. Each is a step-by-step walkthrough
        you'll follow in the real product while reading. Pick the closest to what you do.
      </p>

      <div class="paths">
        {paths.map((p) => (
          <a class="path-card" href={p.href}>
            <div class="ph">
              <ProductIcon kind={p.kind} size={36} />
              <span class="time">{p.time}</span>
            </div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
            <span class="go">Start build →</span>
          </a>
        ))}
      </div>

      <div class="callout">
        <strong>The pattern that always works.</strong> Goal → constraints → success criteria → ask one clarifying question.
        Iteration is the unit of progress. Every step is yours to skip or revisit — your progress is saved.
      </div>
    </LessonShell>
  </main>
</Layout>

<style>
  .paths {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.8rem;
    margin: 1.2rem 0;
  }
  @media (min-width: 800px) { .paths { grid-template-columns: 1fr 1fr 1fr; } }
  .path-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.05rem 1.1rem 1.1rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .path-card:hover {
    border-color: var(--ink);
    text-decoration: none;
  }
  .path-card .ph {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 0.2rem;
  }
  .path-card .time {
    font-size: 0.7rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }
  .path-card h3 { margin: 0 0 0.2rem; font-size: 1rem; }
  .path-card p { margin: 0; color: var(--ink-soft); font-size: 0.88rem; flex: 1; }
  .path-card .go {
    margin-top: 0.7rem;
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--accent);
  }
  .path-card:hover .go { color: #a64500; }
</style>
