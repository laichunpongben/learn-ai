---
import Layout from "../../layouts/Layout.astro";
import LessonShell from "../../components/LessonShell.astro";
import ProductIcon from "../../components/ProductIcon.astro";
import { LESSONS } from "../../data/curriculum";

const lesson = LESSONS.find((l) => l.id === "ship-it")!;

const writingPrompt = `You are my writing partner. When I paste rough notes, produce:
1. A clean version in my voice — direct, no jargon.
2. A one-sentence subject line.
3. Two alternatives — shorter and more formal.
Ask one clarifying question if context is missing.`;

const webPrompt = `Build a single-page website. Self-contained HTML, no external files.

Purpose: a one-page "what I'm working on" portfolio.
Sections: short intro, three projects, a contact link.
Style: warm, minimal, generous whitespace, serif headings.`;

const cliPrompt = `Write a Python script rename.py that:
- Takes one argument: a folder path.
- Finds all .jpg/.jpeg/.png files.
- Reads EXIF date (fallback to mtime).
- Renames to YYYY-MM-DD__NNN.ext.
- Prints what it'll do and asks before renaming.

Then create samples/ with two fake .jpg files and run as a sanity check.`;
---

<Layout title={`${lesson.title} · Learn Claude`}>
  <main>
    <LessonShell lesson={lesson} hero="ship">
      <p>Pick one. Build it. Keep it.</p>

      <div class="paths">
        <article>
          <div class="ph"><ProductIcon kind="chat" size={36} /><span class="time">~5 min · no install</span></div>
          <h3>A · Writing assistant</h3>
          <p>A saved Claude.ai project that turns rough notes into polished prose in your voice.</p>
          <ol class="mini">
            <li>claude.ai → Projects → New project</li>
            <li>Paste the prompt below into <strong>Custom instructions</strong></li>
            <li>(Optional) Drop in 2–3 writing samples as knowledge</li>
            <li>Start a chat. Paste rough notes. Done.</li>
          </ol>
          <pre>{writingPrompt}</pre>
        </article>

        <article>
          <div class="ph"><ProductIcon kind="design" size={36} /><span class="time">~10 min · no install</span></div>
          <h3>B · Tiny live webpage</h3>
          <p>A working page you can share — portfolio, event invite, calculator.</p>
          <ol class="mini">
            <li>claude.ai → New chat</li>
            <li>Paste the prompt</li>
            <li>Watch the artifact panel render live</li>
            <li>Iterate ("darker background", "add hover animation"), download HTML</li>
          </ol>
          <pre>{webPrompt}</pre>
        </article>

        <article>
          <div class="ph"><ProductIcon kind="code" size={36} /><span class="time">~15 min · Claude Code</span></div>
          <h3>C · Personal script</h3>
          <p>Rename a folder of photos by their EXIF dates.</p>
          <ol class="mini">
            <li><code class="inline">mkdir photo-renamer &amp;&amp; cd photo-renamer</code></li>
            <li><code class="inline">claude</code></li>
            <li>Paste the prompt</li>
            <li>Approve the actions it asks about</li>
          </ol>
          <pre>{cliPrompt}</pre>
        </article>
      </div>

      <div class="callout">
        <strong>The pattern that always works.</strong> Goal → constraints → success criteria → ask one clarifying question.
        Iteration is the unit of progress.
      </div>
    </LessonShell>
  </main>
</Layout>

<style>
  .paths {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 1.2rem 0;
  }
  .paths article {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1rem 1.1rem;
  }
  .paths .ph {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.5rem;
  }
  .paths .time {
    font-size: 0.72rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }
  .paths h3 { margin: 0 0 0.3rem; font-size: 1rem; }
  .paths p { margin: 0 0 0.5rem; color: var(--ink-soft); font-size: 0.9rem; }
  .paths .mini { padding-left: 1.1rem; font-size: 0.88rem; margin: 0.4rem 0 0.6rem; }
  .paths .mini li { margin: 0.1rem 0; }
  .paths pre { font-size: 0.78rem; }
</style>
