---
import Layout from "../../layouts/Layout.astro";
import LessonShell from "../../components/LessonShell.astro";
import ProductIcon from "../../components/ProductIcon.astro";
import { LESSONS } from "../../data/curriculum";

const lesson = LESSONS.find((l) => l.id === "ship-it")!;

// Ordered by friction so a first-time builder hits the easiest path first.
// `badge` surfaces the dominant requirement; `recommended` flags the
// suggested starter. See ADR-0007.
const paths = [
  {
    kind: "chat" as const,
    href: "/lessons/build-writing",
    title: "A · Writing assistant",
    desc: "Build a saved Project / Custom GPT / Gem you'll use whenever you need to draft writing.",
    time: "~10 min · no install",
    badge: "Easiest",
    recommended: true,
  },
  {
    kind: "design" as const,
    href: "/lessons/build-webpage",
    title: "B · Live webpage",
    desc: "A working one-page website (portfolio, event invite, calculator) you can share.",
    time: "~15 min · no install",
    badge: "No-install",
    recommended: false,
  },
  {
    kind: "code" as const,
    href: "/lessons/build-script",
    title: "C · Personal script",
    desc: "A tiny CLI tool on your machine — rename photos by EXIF date — via a coding CLI.",
    time: "~20 min · coding CLI required",
    badge: "Terminal",
    recommended: false,
  },
  {
    kind: "agents" as const,
    href: "/lessons/build-slackbot",
    title: "D · Slack digest bot",
    desc: "A bot that posts a daily channel summary. Real API tokens + scheduling.",
    time: "~25 min · coding CLI + Slack workspace",
    badge: "Terminal · Slack",
    recommended: false,
  },
  {
    kind: "cowork" as const,
    href: "/lessons/build-watcher",
    title: "E · Scheduled watcher",
    desc: "A Cowork agent that scans a feed every hour and pings you when something matters. Plan → build → schedule.",
    time: "~30 min · Claude Cowork (Pro/Max)",
    badge: "Paid plan",
    recommended: false,
  },
];
---

<Layout title={`${lesson.title} · Learn AI`} description={lesson.blurb} currentId="ship-it">
    <LessonShell lesson={lesson} hero="ship">
      <p>
        Five paths, all ending with a tool you actually keep. Each is a step-by-step walkthrough
        you'll follow in the real product while reading. Pick the closest to what you do.
      </p>
      <p style="color: var(--ink-soft); font-size: 0.92rem;">
        <strong>First build?</strong> Start with <strong>A</strong>. It needs nothing installed —
        just a chat app you already use.
      </p>

      <div class="paths">
        {paths.map((p) => (
          <a class={`path-card${p.recommended ? " recommended" : ""}`} href={p.href}>
            <div class="ph">
              <ProductIcon kind={p.kind} size={36} />
              <span class="badge">{p.badge}</span>
              <span class="time">{p.time}</span>
            </div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
            <span class="go">Start build →</span>
          </a>
        ))}
      </div>

      <div class="callout">
        <strong>The pattern that always works.</strong> Goal → constraints → success criteria → ask one clarifying question.
        Iteration is the unit of progress. Every step is yours to skip or revisit — your progress is saved.
      </div>
    </LessonShell>
</Layout>

<style>
  .paths {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.8rem;
    margin: 1.2rem 0;
  }
  @media (min-width: 800px) { .paths { grid-template-columns: 1fr 1fr 1fr; } }
  .path-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.05rem 1.1rem 1.1rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .path-card:hover {
    border-color: var(--ink);
    text-decoration: none;
  }
  .path-card .ph {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.2rem;
    flex-wrap: wrap;
  }
  .path-card .time {
    font-size: 0.7rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
    margin-left: auto;
  }
  .path-card .badge {
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    color: var(--ink-soft);
    background: var(--surface-2);
    border: 1px solid var(--line);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
  }
  .path-card.recommended {
    border-color: var(--accent);
    border-left-width: 2px;
  }
  .path-card.recommended .badge {
    color: var(--accent);
    background: var(--accent-soft);
    border-color: var(--accent);
  }
  .path-card h3 { margin: 0 0 0.2rem; font-size: 1rem; }
  .path-card p { margin: 0; color: var(--ink-soft); font-size: 0.88rem; flex: 1; }
  .path-card .go {
    margin-top: 0.7rem;
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--accent);
  }
  .path-card:hover .go { color: #a64500; }
</style>
