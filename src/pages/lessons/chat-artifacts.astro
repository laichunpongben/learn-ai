---
import Layout from "../../layouts/Layout.astro";
import LessonShell from "../../components/LessonShell.astro";
import ChatSim from "../../components/ChatSim.astro";
import { LESSONS } from "../../data/curriculum";

const lesson = LESSONS.find((l) => l.id === "chat-artifacts")!;
---

<Layout title={`${lesson.title} · Learn AI`} description={lesson.blurb} currentId="chat-artifacts">
    <LessonShell lesson={lesson}>
      <p>
        When the assistant produces something self-contained — a document, code, a webpage — it pops out
        into a side panel. <strong>Claude</strong> calls them <em>artifacts</em>; <strong>ChatGPT</strong>
        calls it <em>Canvas</em>; <strong>Gemini</strong> calls it <em>Canvas</em> too. Same idea, different label.
      </p>

      <ChatSim prompts={["Write a thank-you note", "Plan a 3-day Tokyo trip", "Build me a simple webpage"]} />

      <h2>What counts</h2>
      <ul>
        <li>Long write-ups, briefs, plans</li>
        <li>Single files of code</li>
        <li>Mini-apps that preview live (HTML/React)</li>
        <li>Diagrams (Mermaid flowcharts, sequence)</li>
      </ul>

      <p style="color: var(--ink-soft); font-size: 0.92rem;">
        Casual replies stay in the conversation. Anything you'd want to keep moves to the panel,
        where you can edit, iterate, copy, or download.
      </p>
    </LessonShell>
</Layout>
