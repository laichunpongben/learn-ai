---
import Layout from "../../layouts/Layout.astro";
import LessonShell from "../../components/LessonShell.astro";
import { LESSONS } from "../../data/curriculum";

const lesson = LESSONS.find((l) => l.id === "agents-landscape")!;

const agents = [
  { name: "Hermes Agent",  who: "Nous Research",  what: "Background daemon. Persistent memory, scheduled tasks, Telegram/Discord.", url: "https://github.com/NousResearch/hermes-agent" },
  { name: "OpenClaw",      who: "Open source",    what: "Multi-agent runtime. Coordinates multiple coding CLIs as one.", url: "https://docs.openclaw.ai" },
  { name: "aider",         who: "Open source",    what: "Terminal pair programming. Mature, git-aware, multi-model.", url: "https://aider.chat" },
  { name: "OpenHands",     who: "All Hands AI",   what: "Autonomous engineer in a web UI. Local + customisable.", url: "https://github.com/All-Hands-AI/OpenHands" },
  { name: "Goose",         who: "Block",          what: "Extensible CLI/desktop agent. Strong tool ecosystem.", url: "https://block.github.io/goose/" },
  { name: "AutoGen",       who: "Microsoft",      what: "Multi-agent conversation framework. Python-first.", url: "https://github.com/microsoft/autogen" },
  { name: "crewAI",        who: "crewAI",         what: "Role-based agent orchestration. Great for workflow automation.", url: "https://www.crewai.com" },
  { name: "Continue / Cline", who: "Various",     what: "IDE-embedded copilots inside VS Code.", url: "https://continue.dev" },
];
---

<Layout title={`${lesson.title} · Learn AI`} description={lesson.blurb} currentId="agents-landscape">
  <main>
    <LessonShell lesson={lesson} hero="agents">
      <p>
        <strong>Open-source autonomous agents</strong> are tools that wrap an LLM — usually any LLM — into a different
        shape than a chat or a CLI. Background daemons, multi-agent runtimes, IDE plugins, web sandboxes.
        You self-host them, give them an API key, and they go to work.
      </p>

      <div class="agent-list">
        {agents.map((a) => (
          <article>
            <header>
              <h3>{a.name}</h3>
              <span>{a.who}</span>
            </header>
            <p>{a.what}</p>
            {a.url ? <a href={a.url} target="_blank" rel="noopener" class="ext">{a.url.replace(/^https?:\/\//, '')}</a> : null}
          </article>
        ))}
      </div>

      <div class="callout">
        <strong>When to reach for these.</strong> When the polished products don't cover your case:
        background execution, cross-session memory, custom tool integrations, multi-agent orchestration,
        running fully on your own infrastructure, or swapping providers freely.
      </div>

      <p style="color: var(--ink-soft); font-size: 0.9rem;">
        All of these are model-agnostic — you can point them at OpenAI, Anthropic, Google, Mistral, DeepSeek,
        or a local Ollama model. The next lesson explains how that wiring works.
      </p>
    </LessonShell>
  </main>
</Layout>

<style>
  .agent-list {
    border-top: 1px solid var(--line);
    margin: 1rem 0 1.5rem;
  }
  .agent-list article {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--line);
  }
  .agent-list header {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
  }
  .agent-list h3 { margin: 0; font-size: 0.95rem; }
  .agent-list header span {
    font-size: 0.72rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .agent-list p {
    margin: 0.25rem 0 0.3rem;
    color: var(--ink-soft);
    font-size: 0.9rem;
  }
  .agent-list .ext {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--ink-faint);
    border: none;
  }
  .agent-list .ext:hover { color: var(--ink); border: none; }
</style>
