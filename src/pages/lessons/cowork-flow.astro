---
import Layout from "../../layouts/Layout.astro";
import LessonShell from "../../components/LessonShell.astro";
import CoworkSim from "../../components/CoworkSim.astro";
import Screencast from "../../components/Screencast.astro";
import { LESSONS } from "../../data/curriculum";

const lesson = LESSONS.find((l) => l.id === "cowork-flow")!;
---

<Layout title={`${lesson.title} · Learn AI`} description={lesson.blurb} currentId="cowork-flow">
    <LessonShell lesson={lesson}>
      <p>
        Every cloud-agent platform has roughly the same flow. The imitation below shows the pattern.
        Hit <strong>▶ Run all</strong> — tasks run in parallel. Click each to see the diff. Approve or discard.
      </p>

      <Screencast slot="cowork-loop" />

      <CoworkSim />

      <div class="flow">
        <div><strong>1. Submit</strong><span>Repo + goal. Afternoon-sized.</span></div>
        <div><strong>2. Run</strong><span>Own sandbox per task.</span></div>
        <div><strong>3. Review</strong><span>File diff + test results.</span></div>
        <div><strong>4. Decide</strong><span>Merge / comment / discard.</span></div>
      </div>

      <h2>A good task prompt names three things</h2>
      <ul>
        <li><strong>Outcome.</strong> What does "done" look like?</li>
        <li><strong>Constraints.</strong> "Don't touch the API." "Match the settings page style."</li>
        <li><strong>Verify.</strong> "Tests pass." "Clicking the toggle switches colours."</li>
      </ul>

      <div class="callout">
        <strong>Same shape across vendors.</strong> Devin's "task", Cowork's "task", Copilot Workspace's "spec",
        Codex Cloud's "session" all behave like the boxes on the left. The diff review is GitHub-style across all of them.
      </div>
    </LessonShell>
</Layout>

<style>
  .flow {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    margin: 1.4rem 0;
  }
  .flow > div {
    padding: 0.8rem 0.9rem;
    background: var(--surface);
    border-right: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .flow > div:last-child { border-right: none; }
  .flow strong { font-size: 0.88rem; }
  .flow span { font-size: 0.8rem; color: var(--ink-soft); }
  @media (max-width: 720px) {
    .flow { grid-template-columns: 1fr 1fr; }
    .flow > div:nth-child(2) { border-right: none; }
    .flow > div:nth-child(-n+2) { border-bottom: 1px solid var(--line); }
  }
</style>
