---
import Layout from "../../layouts/Layout.astro";
import LessonShell from "../../components/LessonShell.astro";
import ChatSim from "../../components/ChatSim.astro";
import ProductRow from "../../components/ProductRow.astro";
import { LESSONS } from "../../data/curriculum";

const lesson = LESSONS.find((l) => l.id === "welcome")!;
---

<Layout title={`${lesson.title} · Learn Claude`}>
  <main>
    <LessonShell lesson={lesson} hero="claude">
      <p>
        Claude is an AI assistant. You type what you want; it types back.
        That's the whole product. What changes from one Claude product to the next is the
        <strong>shape</strong> of "talking to Claude".
      </p>

      <ProductRow />

      <h2>Try it</h2>
      <p>This is an imitation of <code class="inline">claude.ai</code> — drive it like the real thing.</p>
      <ChatSim prompts={["Hi", "Write a thank-you note", "Plan a 3-day Tokyo trip"]} />

      <div class="callout">
        <strong>One thing to know.</strong> AI assistants can sound confident and still be wrong.
        Treat Claude as a first draft, not a final answer.
      </div>
    </LessonShell>
  </main>
</Layout>
