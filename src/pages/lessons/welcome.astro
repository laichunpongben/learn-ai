---
import Layout from "../../layouts/Layout.astro";
import LessonShell from "../../components/LessonShell.astro";
import ChatSim from "../../components/ChatSim.astro";
import ProductRow from "../../components/ProductRow.astro";
import { LESSONS } from "../../data/curriculum";

const lesson = LESSONS.find((l) => l.id === "welcome")!;
---

<Layout title={`${lesson.title} · Learn AI`} description={lesson.blurb} currentId="welcome">
    <LessonShell lesson={lesson}>
      <p>
        An <strong>AI assistant</strong> is software that takes a request in plain language and gives you
        something back — text, code, an answer, a working webpage. You type what you want; it types back.
        That's the entire user interface.
      </p>
      <p>
        Today there are <em>many</em> assistants — ChatGPT, Claude, Gemini, Cursor, Devin, v0, and dozens more.
        Underneath, they're powered by large language models (LLMs) from companies like OpenAI, Anthropic, Google,
        Meta, Mistral, DeepSeek. The product you open just decides the <strong>shape</strong> of the interaction.
      </p>

      <ProductRow />

      <h2>Try it</h2>
      <p>This is an imitation of a chat-style assistant. Drive it like any of the real ones.</p>
      <ChatSim prompts={["Hi", "Write a thank-you note", "Plan a 3-day Tokyo trip"]} />

      <div class="callout">
        <strong>One thing to know.</strong> Every assistant can sound confident and still be wrong.
        Treat the output as a first draft, not a final answer — especially for facts, numbers, and code.
      </div>
    </LessonShell>
</Layout>
