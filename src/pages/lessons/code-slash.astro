---
import Layout from "../../layouts/Layout.astro";
import LessonShell from "../../components/LessonShell.astro";
import FakeTerminal from "../../components/FakeTerminal.astro";
import { LESSONS } from "../../data/curriculum";

const lesson = LESSONS.find((l) => l.id === "code-slash")!;
---

<Layout title={`${lesson.title} · Learn Claude`}>
  <main>
    <LessonShell lesson={lesson}>
      <p>Drive the terminal imitation. Press <kbd>/</kbd>, type, hit Enter. Watch streaming + approval prompts.</p>

      <FakeTerminal cwd="~/my-project" />

      <h2>Try these</h2>
      <ul>
        <li><code class="inline">/agents</code> — list specialized assistants</li>
        <li><em>"fix the bug"</em> — Claude reads files, runs tests, finds the cause</li>
        <li><em>"add a dark mode toggle"</em> — note the Allow/Deny prompt before any write</li>
      </ul>

      <div class="trio">
        <div>
          <h4>Slash command</h4>
          <p>Do this <em>action</em> now.</p>
        </div>
        <div>
          <h4>Agent</h4>
          <p>Switch to this <em>persona</em>.</p>
        </div>
        <div>
          <h4>Skill</h4>
          <p>Use this <em>recipe</em>.</p>
        </div>
      </div>
    </LessonShell>
  </main>
</Layout>

<style>
  .trio {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.5rem;
    margin: 1.2rem 0;
  }
  .trio > div {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.8rem 0.9rem;
  }
  .trio h4 { margin: 0 0 0.25rem; font-size: 0.88rem; }
  .trio p { margin: 0; color: var(--ink-soft); font-size: 0.86rem; }
  @media (max-width: 600px) { .trio { grid-template-columns: 1fr; } }
</style>
