---
import Layout from "../../layouts/Layout.astro";
import LessonShell from "../../components/LessonShell.astro";
import ChatSim from "../../components/ChatSim.astro";
import { LESSONS } from "../../data/curriculum";

const lesson = LESSONS.find((l) => l.id === "chat-first")!;
---

<Layout title={`${lesson.title} · Learn Claude`}>
  <main>
    <LessonShell lesson={lesson}>
      <p>Drive the imitation. Try a suggestion. Open a new chat from the sidebar.</p>

      <ChatSim prompts={["Hi", "Write a thank-you note", "Plan a 3-day Tokyo trip", "Build me a simple webpage"]} />

      <h2>What the real app adds</h2>
      <ul>
        <li>An account; chats persist across devices.</li>
        <li><strong>File upload</strong> — PDFs, images, spreadsheets.</li>
        <li><strong>Model picker</strong> — Sonnet / Opus / Haiku.</li>
        <li><strong>Projects</strong> (next lesson).</li>
      </ul>

      <div class="callout">
        <strong>Why not Claude Code for everything?</strong> If you're in a project folder, often you should.
        Reach for claude.ai when: not at a dev machine; task isn't about code; you want to drop in a file;
        a non-developer needs to use it.
      </div>
    </LessonShell>
  </main>
</Layout>
