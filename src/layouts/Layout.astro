---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import SearchPalette from "../components/SearchPalette.astro";

interface Props {
  title: string;
  description?: string;
  currentId?: string;
}

const { title, description = "A hands-on tour of modern AI assistants and agents.", currentId } = Astro.props;
// Use the bare page title (everything before " · ") as the og:title.
const ogTitle = title.includes(" · ") ? title.split(" · ")[0] : title;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Learn AI" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      // Runs before any <body> markup parses. Sets initial theme (no flash) and
      // exposes globally-callable functions so HTML onclick handlers always work,
      // regardless of any module-script load timing.
      (function () {
        var KEY = "learn-ai.theme.v1";

        function readTheme() {
          try {
            var s = localStorage.getItem(KEY);
            if (s === "light" || s === "dark") return s;
          } catch (_e) {}
          try {
            if (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) return "dark";
          } catch (_e) {}
          return "light";
        }

        function writeTheme(t) {
          document.documentElement.setAttribute("data-theme", t);
          try { localStorage.setItem(KEY, t); } catch (_e) {}
        }

        // 1. Apply stored / preferred theme NOW, before paint.
        var stored = null;
        try { stored = localStorage.getItem(KEY); } catch (_e) {}
        if (stored === "light" || stored === "dark") {
          document.documentElement.setAttribute("data-theme", stored);
        }

        // 2. Expose a globally-callable toggle. Buttons reference this via onclick.
        window.__toggleTheme = function () {
          var cur = readTheme();
          writeTheme(cur === "dark" ? "light" : "dark");
        };

        // 3. Expose search open/close globally (overlay is added in body).
        window.__openSearch = function () {
          var o = document.querySelector("[data-search-overlay]");
          if (!o) return;
          o.removeAttribute("hidden");
          document.documentElement.style.overflow = "hidden";
          var i = document.querySelector("[data-search-input]");
          if (i) { i.value = ""; setTimeout(function () { i.focus(); }, 0); }
          // Trigger initial render if the palette script attached one
          if (typeof window.__searchRender === "function") window.__searchRender();
        };
        window.__closeSearch = function () {
          var o = document.querySelector("[data-search-overlay]");
          if (!o) return;
          o.setAttribute("hidden", "");
          document.documentElement.style.overflow = "";
        };

        // 4. ⌘K / Ctrl+K open/close from any focus state.
        document.addEventListener("keydown", function (e) {
          if ((e.metaKey || e.ctrlKey) && (e.key === "k" || e.key === "K")) {
            e.preventDefault();
            var o = document.querySelector("[data-search-overlay]");
            if (!o) return;
            if (o.hasAttribute("hidden")) window.__openSearch();
            else window.__closeSearch();
          } else if (e.key === "Escape") {
            var o2 = document.querySelector("[data-search-overlay]");
            if (o2 && !o2.hasAttribute("hidden")) window.__closeSearch();
          }
        });

        // 5. Document-level click delegation as a third belt-and-braces fallback,
        //    in case onclick attributes are blocked by a CSP or browser extension.
        document.addEventListener("click", function (e) {
          var t = e.target;
          if (!t || typeof t.closest !== "function") return;
          if (t.closest("[data-theme-toggle]")) { window.__toggleTheme(); return; }
          if (t.closest("[data-search-open]"))  { window.__openSearch();  return; }
          if (t.closest("[data-search-close]")) { window.__closeSearch(); return; }
        });
      })();
    </script>
  </head>
  <body>
    <header class="site">
      <div class="inner">
        <button
          type="button"
          class="hamburger"
          data-sidebar-toggle
          aria-label="Open navigation"
          aria-expanded="false"
        >
          <span></span><span></span><span></span>
        </button>
        <a href="/" class="brand">Learn AI</a>
        <span class="spacer"></span>
        <SearchPalette />
        <a class="tiny-link" href="/">Curriculum</a>
        <a class="tiny-link" href="/cookbook">Cookbook</a>
        <ThemeToggle />
      </div>
    </header>
    <div class="shell">
      <Sidebar currentId={currentId} />
      <slot />
    </div>
    <div class="sidebar-backdrop" data-sidebar-backdrop hidden></div>
    <footer>
      <p>Self-paced. Progress lives only in your browser. <a href="/">Curriculum</a> · <a href="/cookbook">Cookbook</a></p>
    </footer>

    <script>
      const html = document.documentElement;
      const backdrop = document.querySelector<HTMLElement>("[data-sidebar-backdrop]");

      function open() {
        html.classList.add("sidebar-open");
        document
          .querySelector<HTMLButtonElement>("[data-sidebar-toggle]")
          ?.setAttribute("aria-expanded", "true");
        if (backdrop) backdrop.hidden = false;
      }
      function close() {
        html.classList.remove("sidebar-open");
        document
          .querySelector<HTMLButtonElement>("[data-sidebar-toggle]")
          ?.setAttribute("aria-expanded", "false");
        if (backdrop) backdrop.hidden = true;
      }

      document.querySelectorAll<HTMLButtonElement>("[data-sidebar-toggle]").forEach((btn) => {
        btn.addEventListener("click", () => {
          if (html.classList.contains("sidebar-open")) close();
          else open();
        });
      });
      backdrop?.addEventListener("click", close);
      window.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && html.classList.contains("sidebar-open")) close();
      });
      document.querySelectorAll<HTMLAnchorElement>(".sidebar a").forEach((a) => {
        a.addEventListener("click", () => {
          if (window.matchMedia("(max-width: 960px)").matches) close();
        });
      });
    </script>
  </body>
</html>
