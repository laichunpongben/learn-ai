---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Sidebar from "../components/Sidebar.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import SearchPalette from "../components/SearchPalette.astro";

interface Props {
  title: string;
  description?: string;
  currentId?: string;
  noindex?: boolean;
}

const {
  title,
  description = "A hands-on tour of modern AI assistants and agents.",
  currentId,
  noindex = false,
} = Astro.props;
const ogTitle = title.includes(" · ") ? title.split(" · ")[0] : title;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const ogImage = new URL("/og.png", Astro.site ?? Astro.url.origin).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fbfbfa" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0d0e10" media="(prefers-color-scheme: dark)" />
    <!-- Open DNS + TLS to the font CDN in parallel with the main CSS download,
         instead of waiting for a chained @import inside global.css. -->
    <link rel="preconnect" href="https://rsms.me" crossorigin />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <meta name="description" content={description} />
    <meta name="keywords" content="AI assistants, Claude, ChatGPT, Gemini, prompt engineering, AI agents, MCP, RAG, evals, AI tutorial, beginner" />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Learn AI" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Learn AI · Lessons" href="/rss.xml" />
    <title>{title}</title>
    <!-- No-flash theme apply. Only sets [data-theme] from localStorage before paint;
         all interaction logic lives in src/scripts/ui.ts, imported below. -->
    <script is:inline>
      (function () {
        try {
          var s = localStorage.getItem("learn-ai.theme.v1");
          if (s === "light" || s === "dark") {
            document.documentElement.setAttribute("data-theme", s);
          }
        } catch (_e) {}
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <div class="read-progress" data-read-progress aria-hidden="true"><span></span></div>
    <header class="site">
      <div class="inner">
        <button
          type="button"
          class="hamburger"
          data-ui-action="toggle-sidebar"
          aria-label="Open navigation"
          aria-expanded="false"
        >
          <span></span><span></span><span></span>
        </button>
        <a href="/" class="brand">Learn AI</a>
        <span class="spacer"></span>
        <SearchPalette />
        <ThemeToggle />
      </div>
    </header>
    <div class="shell">
      <Sidebar currentId={currentId} />
      <main id="main"><slot /></main>
    </div>
    <div class="sidebar-backdrop" data-ui-action="close-sidebar"></div>
    <Footer />
    <script>
      import "../scripts/ui";
      import "../scripts/pwa";
    </script>
  </body>
</html>
