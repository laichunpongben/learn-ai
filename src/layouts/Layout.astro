---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";

interface Props {
  title: string;
  description?: string;
  currentId?: string;
}

const { title, description = "A hands-on tour of modern AI assistants and agents.", currentId } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site">
      <div class="inner">
        <a href="/" class="brand">Learn AI</a>
        <span class="spacer"></span>
        <a class="tiny-link" href="/">Curriculum</a>
        <a class="tiny-link" href="/cookbook">Cookbook</a>
      </div>
    </header>
    <div class="shell">
      <Sidebar currentId={currentId} />
      <slot />
    </div>
    <footer>
      <p>Self-paced. Progress lives only in your browser. <a href="/">Curriculum</a> · <a href="/cookbook">Cookbook</a></p>
    </footer>
  </body>
</html>
